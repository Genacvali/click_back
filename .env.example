# ── ClickHouse ──────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=clickhouse.internal
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=backup_user
CLICKHOUSE_PASSWORD=supersecret
# Конкретная БД или ALL для полного бэкапа кластера
CLICKHOUSE_DATABASE=metrics_db
# Выбор клиента: auto (по умолчанию), connect (HTTP/clickhouse-connect), driver (TCP/clickhouse-driver)
CLICKHOUSE_CLIENT=auto

# ── S3 / MinIO ──────────────────────────────────────────────────────────────
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=my-clickhouse-backups
S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# Папка внутри бакета; итоговый путь: s3://bucket/prefix/db_2026-06-08_02-30-00.zip
S3_PATH_PREFIX=clickhouse-backups

# ── Поведение скрипта ───────────────────────────────────────────────────────
# Сколько дней хранить бэкапы (0 — retention отключён)
BACKUP_RETENTION_DAYS=30

# Максимальное время ожидания завершения бэкапа в секундах
BACKUP_TIMEOUT_SECONDS=3600

# Интервал опроса system.backups, секунды
BACKUP_POLL_INTERVAL_SECONDS=15

# Режим сухого прогона: только печатает SQL и S3-путь, не запускает бэкап
DRY_RUN=false
