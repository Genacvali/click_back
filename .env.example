# ── ClickHouse ──────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=127.0.0.1
# TCP-порт (не HTTP): clickhouse-backup работает через нативный протокол
CLICKHOUSE_TCP_PORT=9000
CLICKHOUSE_USER=backup_user
CLICKHOUSE_PASSWORD=supersecret
# Конкретная БД или ALL для полного бэкапа
CLICKHOUSE_DATABASE=metrics_db
# Путь к данным ClickHouse на диске
CLICKHOUSE_DATA_PATH=/var/lib/clickhouse
# TLS для подключения к ClickHouse (true/false)
CLICKHOUSE_SECURE=false
# Путь к бинарнику clickhouse-backup (если не в $PATH)
CLICKHOUSE_BACKUP_BINARY=clickhouse-backup

# ── S3 / MinIO ──────────────────────────────────────────────────────────────
S3_BUCKET=my-clickhouse-backups
S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_REGION=us-east-1
# Для MinIO или других S3-совместимых хранилищ — указать URL:
# S3_ENDPOINT=https://minio.internal:9000
S3_ENDPOINT=
# Папка внутри бакета: s3://bucket/prefix/backup_name/
S3_PATH_PREFIX=clickhouse-backups
# true — обязательно для MinIO и Ceph (path-style addressing)
S3_FORCE_PATH_STYLE=false
S3_DISABLE_SSL=false
# Формат архива: tar (совместим с CH 21), gz, bz2, zstd
S3_COMPRESSION_FORMAT=tar
S3_COMPRESSION_LEVEL=1
# Параллельных потоков при загрузке в S3
S3_CONCURRENCY=2

# ── Поведение скрипта ───────────────────────────────────────────────────────
# Сколько дней хранить бэкапы (0 — retention отключён)
BACKUP_RETENTION_DAYS=30
# Максимальное время выполнения бэкапа в секундах
BACKUP_TIMEOUT_SECONDS=3600
# true — только напечатает команду и S3-путь, не запустит бэкап
DRY_RUN=false
